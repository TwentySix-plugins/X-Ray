{% extends "_layouts/cp" %}

{% set title = "X-Ray" %}
{% set showHeader = false %}  {# drop the CP page title; the toolbar labels it #}
{% set siteUrl = siteUrl ?? '' %}

{# Fonts (Inter + JetBrains Mono) are bundled locally via XRayCpAsset — no
   external Google Fonts request. The bundle is registered in ViewerController. #}

{% block content %}
<style>
#xr-app, #xr-app *, #xr-app *::before, #xr-app *::after { box-sizing: border-box; }
#xr-app { margin: 0; padding: 0; }
#xr-app h1, #xr-app h2, #xr-app h3, #xr-app p, #xr-app ul, #xr-app ol, #xr-app li { margin: 0; padding: 0; }
#xr-app input { margin: 0; }

/* Let X-Ray fill the CP content area edge-to-edge (Craft normally
   constrains + centers the content column, which squashes the panel).
   This <style> only renders on the X-Ray page, so targeting the CP
   wrappers directly is safe — no body class needed. */
#global-header { margin-bottom: 0 !important; }
#main { padding: 0 !important; }
#main-content { padding: 0 !important; display: block !important; width: auto !important; }
#content-container { padding: 0 !important; max-width: none !important; width: 100% !important; }
.content-grid { display: block !important; max-width: none !important; width: 100% !important; margin: 0 !important; }
.content-grid__main { max-width: none !important; width: 100% !important; }
#content,
#content.content-pane {
  padding: 12px !important;
  max-width: none !important;
  width: auto !important;
  margin: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  border: 0 !important;
}
#xr-app { width: 100%; }

#xr-app {
  /* Mapped onto Craft CP design tokens so X-Ray matches the admin
     colour palette (and follows Craft's light/dark theme automatically). */
  --bg:          var(--gray-100);
  --surface:     var(--white);
  --surface2:    var(--gray-100);
  --border:      var(--hairline-color);
  --accent:      var(--blue-600);
  --accent-h:    var(--blue-700);
  --accent-soft: rgb(from var(--blue-600) r g b / 0.12);
  --accent-ring: rgb(from var(--blue-600) r g b / 0.22);
  --text:        var(--text-color);
  --muted:       var(--medium-text-color);
  --success:     var(--success-color);
  --warn:        var(--warning-color);
  --pink:        var(--blue-700);
  --mono:        'JetBrains Mono', 'SFMono-Regular', Consolas, monospace;
  --sans:        'Inter', system-ui, sans-serif;
}

#xr-app {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  font-size: 13px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
  border-left: 1px solid var(--border);
}

/* ─── Layout ────────────────────────────────────────────────────── */
#xr-app {
  display: flex;
  flex-direction: column;
  height: 70vh; /* fallback — JS sets the exact fill height below the CP header */
}

/* ─── Top bar ───────────────────────────────────────────────────── */
#topbar {
  display: flex;
  align-items: center;
  gap: 10px;
  height: 48px;
  padding: 0 14px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  user-select: none;
}

.logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.01em;
  color: var(--text);
  white-space: nowrap;
  padding-right: 4px;
}

.divider {
  width: 1px;
  height: 24px;
  background: var(--border);
  flex-shrink: 0;
}

/* Inspect toggle */
#btn-inspect {
  display: flex;
  align-items: center;
  gap: 6px;
  height: 30px;
  padding: 0 12px;
  border-radius: 6px;
  border: 1.5px solid transparent;
  background: transparent;
  color: var(--muted);
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
}
#btn-inspect:hover { background: var(--surface2); color: var(--text); }
#btn-inspect.on {
  background: var(--text);
  color: var(--bg);
}
#btn-inspect svg { flex-shrink: 0; }

/* Address bar */
#addr-wrap {
  flex: 0 1 420px;
  max-width: 420px;
  display: flex;
  align-items: center;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  height: 30px;
  overflow: hidden;
  min-width: 0;
}
#addr-wrap:focus-within {
  border-color: var(--text);
}
#addr {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: var(--text);
  font-family: var(--mono);
  font-size: 11.5px;
  padding: 0 10px;
}
#addr::placeholder { color: var(--muted); }
#btn-go {
  height: 100%;
  padding: 0 14px;
  border: none;
  background: var(--text);
  color: var(--bg);
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.15s;
  font-family: var(--sans);
}
#btn-go:hover { opacity: 0.85; }

/* Refresh */
#btn-reload {
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  border: 1.5px solid transparent;
  background: transparent;
  color: var(--muted);
  cursor: pointer;
  transition: all 0.15s;
  flex-shrink: 0;
}
#btn-reload:hover { background: var(--surface2); color: var(--text); }

/* Status pill (xr- prefixed so Craft's own .status dot styling can't bleed in) */
#xr-status {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  line-height: 1;
  padding: 4px 2px;
  background: transparent;
  white-space: nowrap;
  flex-shrink: 0;
}
#xr-status::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
}
#xr-status.xr-idle    { color: var(--muted); }
#xr-status.xr-loading { color: var(--warn); }
#xr-status.xr-ready   { color: var(--success); }

/* ─── Main split ────────────────────────────────────────────────── */
#main {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ─── Iframe pane ───────────────────────────────────────────────── */
#frame-pane {
  flex: 1;
  position: relative;
  overflow: hidden;
  background: #fff;
}

#progress {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--accent);
  z-index: 10;
  transform-origin: left;
  transform: scaleX(0);
  opacity: 0;
  transition: opacity 0.2s;
}
#progress.run {
  opacity: 1;
  animation: prog 1.5s ease-in-out infinite;
}
@keyframes prog {
  0%   { transform: scaleX(0); }
  60%  { transform: scaleX(0.75); }
  100% { transform: scaleX(0.9); }
}

#xr-iframe {
  width: 100%;
  height: 100%;
  border: none;
  display: block;
  transition: opacity 0.2s;
}
#xr-iframe.dim { opacity: 0.4; pointer-events: none; }

/* ─── Sidebar ───────────────────────────────────────────────────── */
#sidebar {
  width: 340px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  background: var(--surface);
  border-left: 1px solid var(--border);
  overflow: hidden;
  padding: 0 !important;
}

#sb-tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.sb-tab {
  flex: 1;
  height: 36px;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--muted);
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.15s;
}
.sb-tab:hover { color: var(--text); }
.sb-tab.active { color: var(--accent-h); border-bottom-color: var(--accent); }

#sb-body {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
  display: flex;
  flex-direction: column;
  padding: 20px 16px;
}

/* Empty state */
#empty {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  padding: 32px 24px;
  text-align: center;
}
#empty svg { color: var(--border); }
#empty h3 { font-size: 14px; font-weight: 600; color: var(--text); }
#empty p { font-size: 12px; color: var(--muted); line-height: 1.7; }
#empty kbd {
  display: inline-block;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1px 6px;
  font-family: var(--mono);
  font-size: 10px;
  color: var(--accent-h);
}

/* ─── Info panel sections ───────────────────────────────────────── */
.xr-sec {
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 20px;
}
.xr-sec:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}
.xr-sec-hd {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  background: var(--surface2);
  border-radius: 5px;
  padding: 5px 10px;
  margin-bottom: 14px;
}
.xr-sec-meta {
  font-family: var(--mono);
  font-weight: 600;
  letter-spacing: 0;
  color: var(--text);
  background: var(--border);
  border-radius: 100px;
  padding: 1px 7px;
  font-size: 10px;
}

/* Component identity */
.xr-name-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.xr-name { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--text); word-break: break-all; }
.xr-badge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 100px;
  flex-shrink: 0;
}
.xr-badge-inner  { background: var(--accent-soft); color: var(--accent-h); }
.xr-badge-parent { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }
.xr-badge-root   { background: var(--surface2); color: var(--text);  border: 1px solid var(--border); }

/* File path (click to copy) */
.xr-file {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  text-align: left;
  font-family: var(--mono);
  font-size: 11.5px;
  color: var(--text);
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 9px 10px;
  cursor: pointer;
  transition: border-color 0.15s;
}
.xr-file:hover { border-color: var(--accent); }
.xr-file-path { flex: 1; word-break: break-all; line-height: 1.4; }
.xr-file-copy { flex-shrink: 0; color: var(--muted); font-size: 13px; }
.xr-file:hover .xr-file-copy { color: var(--accent); }

/* Hierarchy tree */
.xr-tree { display: flex; flex-direction: column; gap: 2px; }
.xr-node {
  display: flex;
  align-items: center;
  gap: 7px;
  width: 100%;
  text-align: left;
  background: transparent;
  border: 1px solid transparent;
  border-radius: 6px;
  padding: 6px 10px;
  cursor: pointer;
  font-family: var(--mono);
  font-size: 12px;
  color: var(--muted);
  transition: background 0.12s, color 0.12s;
}
.xr-node:hover { background: var(--surface2); color: var(--text); }
.xr-node.sel { background: var(--accent-soft); border-color: var(--accent); color: var(--accent-h); font-weight: 700; }
.xr-node-twig { color: var(--muted); flex-shrink: 0; }
.xr-node-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.xr-node-tag {
  font-size: 8.5px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--muted);
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 1px 6px;
  flex-shrink: 0;
}
.xr-node-count {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 700;
  color: var(--accent-h);
  background: var(--accent-soft);
  border: 1px solid var(--accent-ring);
  border-radius: 100px;
  padding: 0 6px;
  flex-shrink: 0;
}

/* "Rendered N× on page" badge in the Component header */
.xr-count-badge {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 700;
  color: var(--accent-h);
  background: var(--accent-soft);
  border: 1px solid var(--accent-ring);
  border-radius: 100px;
  padding: 2px 8px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* Copy button (section header action) */
.xr-copy {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.02em;
  text-transform: none;
  color: var(--muted);
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 5px;
  padding: 2px 6px;
  cursor: pointer;
  transition: color 0.15s, border-color 0.15s;
}
.xr-copy:hover { color: var(--accent); border-color: var(--accent); }
.xr-copy.done  { color: var(--success); border-color: var(--success); }
.xr-copy-ic { font-size: 12px; line-height: 1; }

/* Location — nested folder / file tree */
.xr-loc { display: flex; flex-direction: column; gap: 2px; }
.xr-loc-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--mono);
  font-size: 12px;
  color: var(--muted);
  padding: 3px 0;
}
.xr-loc-file { color: var(--text); font-weight: 600; }
.xr-ic { flex-shrink: 0; }
.xr-loc-folder .xr-ic { color: var(--accent); }
.xr-loc-file .xr-ic   { color: var(--accent-h); }
.xr-loc-name { word-break: break-all; }

/* Props stacked layout */
.props-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.prop-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.pk {
  font-family: var(--mono);
  font-weight: 600;
  color: var(--accent-h);
  font-size: 11px;
  word-break: break-all;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.xr-prop-type {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  color: var(--muted);
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1px 5px;
  letter-spacing: 0.02em;
  flex-shrink: 0;
}
.pv {
  font-family: var(--mono);
  font-size: 11px;
  line-height: 1.5;
  word-break: break-all;
  white-space: pre-wrap;
  padding-left: 10px; /* Reduced left padding */
  border-left: 2px solid var(--accent); /* Craft CMS blue */
}
.pv.null { color: var(--muted); font-style: italic; }
.pv.bool { color: var(--warn); }
.pv.num  { color: var(--success); }
.pv.str  { color: var(--pink); }
.pv.obj  { color: var(--muted); font-size: 10px; }
.xr-prop-link {
  color: var(--muted);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: color 0.15s ease;
}
.xr-prop-link:hover {
  color: var(--accent);
  text-decoration: underline;
}
.xr-prop-link-ic {
  flex-shrink: 0;
  opacity: 0.65;
  transition: opacity 0.15s ease;
}
.xr-prop-link:hover .xr-prop-link-ic {
  opacity: 1;
}

.no-props {
  font-size: 11px;
  color: var(--muted);
  font-style: italic;
}

/* ── Expandable Array / Object tree (Props panel) ─────────────────────── */
.pv-tree { padding-left: 10px; border-left: 2px solid var(--accent); }
.xr-tree-node { }
.xr-tree-sum {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  user-select: none;
  list-style: none;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--accent-h);
  padding: 1px 0;
}
.xr-tree-sum::-webkit-details-marker { display: none; }
.xr-tree-sum::before {
  content: '▶';
  font-size: 8px;
  color: var(--muted);
  transition: transform 0.15s ease;
}
.xr-tree-node[open] > .xr-tree-sum::before { transform: rotate(90deg); }
.xr-tree-sum:hover { color: var(--accent); }
.xr-tree-count {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 700;
  color: var(--text);
  background: var(--border);
  border-radius: 100px;
  padding: 0 6px;
}
.xr-tree-body {
  margin-top: 5px;
  margin-left: 3px;
  padding-left: 9px;
  border-left: 2px solid var(--accent-ring);
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.xr-tree-row { display: flex; gap: 8px; align-items: baseline; }
.xr-tree-key {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 600;
  color: var(--muted);
  flex-shrink: 0;
}
.xr-tree-row > .pv {
  border-left: 0;
  padding-left: 0;
  white-space: pre-wrap;
  word-break: break-word;
}

/* ── Props list ──────────────────────────────────────────────────── */.sb-tab-content {
  display: flex;
  flex-direction: column;
  width: 100%;
}
#main {
  position: relative;
}

/* ── Open-in-editor button + picker ──────────────────────────────────────── */
.xr-editor-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 600;
  border-radius: 5px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--muted);
  cursor: pointer;
  flex-shrink: 0;
  transition: color 0.13s, border-color 0.13s, background 0.13s;
  padding: 2px 6px;
  position: relative;
}
.xr-editor-btn:hover {
  border-color: var(--accent);
  color: var(--accent-h);
  background: var(--accent-soft);
}
/* The editor picker dropdown (Variable mode) */
.xr-editor-picker {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  min-width: 210px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 9px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.10);
  z-index: 9999;
  padding: 6px;
  display: none;
  flex-direction: column;
  gap: 2px;
}
.xr-editor-picker.open { display: flex; }
.xr-editor-picker-title {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  padding: 4px 8px 6px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 4px;
}
.xr-editor-opt {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 7px 10px;
  border-radius: 6px;
  border: none;
  background: transparent;
  cursor: pointer;
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  color: var(--text);
  text-align: left;
  transition: background 0.12s;
  width: 100%;
}
.xr-editor-opt:hover { background: var(--accent-soft); color: var(--accent-h); }
.xr-editor-opt.active { background: var(--accent-soft); color: var(--accent-h); font-weight: 700; }
.xr-editor-opt img {
  width: 16px;
  height: 16px;
  border-radius: 3px;
  flex-shrink: 0;
  object-fit: contain;
}
.xr-editor-opt-name { flex: 1; }
.xr-editor-opt-check {
  font-size: 11px;
  color: var(--accent);
  flex-shrink: 0;
}

</style>

<style>
/* Accent override from plugin Settings — applied last so it wins over the
   Craft-token defaults above. */
#xr-app {
  --accent:      {{ accentColor }};
  --accent-h:    {{ accentColor }};
  --accent-soft: rgb(from {{ accentColor }} r g b / 0.12);
  --accent-ring: rgb(from {{ accentColor }} r g b / 0.22);
  --pink:        {{ accentColor }};
}
</style>

<div id="xr-app">

  <!-- Top Bar -->
  <div id="topbar">
    <button id="btn-inspect" title="Toggle component inspection (Alt+I)">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="22" y1="12" x2="18" y2="12"/>
        <line x1="6" y1="12" x2="2" y2="12"/>
        <line x1="12" y1="6" x2="12" y2="2"/>
        <line x1="12" y1="22" x2="12" y2="18"/>
      </svg>
      <span class="btn-label">Inspect</span>
    </button>

    <div id="addr-wrap">
      <input id="addr" type="text" spellcheck="false" autocomplete="off" placeholder="Enter a URL…">
      <button id="btn-go">GO</button>
    </div>

    <button id="btn-reload" title="Reload">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
      </svg>
    </button>

    <span id="xr-status" class="xr-idle">Idle</span>
  </div>

  <!-- Main -->
  <div id="main">

    <!-- Iframe -->
    <div id="frame-pane">
      <div id="progress"></div>
      <iframe id="xr-iframe" sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-modals"></iframe>
    </div>

    <!-- Sidebar -->
    <div id="sidebar">
      <div id="sb-tabs">
        <button class="sb-tab active" data-tab="component">Component</button>
        <button class="sb-tab" data-tab="globals">Globals</button>
      </div>
      <div id="sb-body">
        <div id="tab-component-content" class="sb-tab-content">
          <div id="empty">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/>
              <line x1="12" y1="22" x2="12" y2="15.5"/>
              <polyline points="22 8.5 12 15.5 2 8.5"/>
            </svg>
            <h3>No component selected</h3>
            <p>Click <kbd>Inspect</kbd> then hover over any element in the viewer to see which Twig template rendered it.</p>
          </div>
        </div>
        <div id="tab-globals-content" class="sb-tab-content" style="display: none;">
          <div id="globals-loading" style="color: var(--muted); font-style: italic;">Loading Global Sets…</div>
          <div id="globals-list" style="display: flex; flex-direction: column;"></div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
(function () {
  const BASE = {{ siteUrl|json_encode|raw }};

  // The origin the inspected site (iframe) runs on. Used to validate inbound
  // postMessages and to target outbound ones — so a page the iframe may have
  // navigated to (e.g. an external link) can't spoof messages into the CP.
  const FRAME_ORIGIN = (() => { try { return new URL(BASE).origin; } catch { return '*'; } })();

  // Settings-driven config (mirrors the front-end client config).
  const CONFIG = {
    param:             {{ activationParam|json_encode|raw }},
    showEditLinks:     {{ showEditLinks ? 'true' : 'false' }},
    blockExternalNav:  {{ blockExternalNav ? 'true' : 'false' }},
    componentPropsUrl: {{ componentPropsUrl|json_encode|raw }},
    editorMode:        {{ editorMode|json_encode|raw }},
    defaultEditor:     {{ defaultEditor|json_encode|raw }},
    // Published URL of the locally-bundled editor logos (no trailing slash).
    editorIconsBaseUrl: {{ editorIconsBaseUrl|json_encode|raw }},
    // Absolute filesystem path to the templates folder (no trailing slash),
    // e.g. <project>/templates — used to build editor deep-links.
    templatesPath:     {{ templatesPath|json_encode|raw }},
  };
  const PARAM = CONFIG.param;
  // Escape the param for safe use inside a RegExp.
  const PARAM_RE = new RegExp('[?&]' + PARAM.replace(/[-/\\^$*+?.()|[\]{}]/g, '\\$&') + '=1\\b');

  // Size X-Ray to fill the available area, independent of Craft's
  // content wrappers: pin it to fill from its left edge to the viewport's
  // right edge, and down to the bottom.
  const ciApp = document.getElementById('xr-app');
  function sizeApp() {
    if (!ciApp) return;
    // Fill the entire CP content region (right of the global nav, below the
    // account bar) via fixed positioning — independent of Craft's wrappers.
    const host = document.getElementById('main-container') || ciApp.parentElement;
    const r = host.getBoundingClientRect();
    // clientWidth/Height exclude the scrollbar, so the panel never slides under
    // it (which was clipping the reload button + status pill on the right).
    const vw = document.documentElement.clientWidth;
    const vh = document.documentElement.clientHeight;
    ciApp.style.position = 'fixed';
    ciApp.style.top    = r.top  + 'px';
    ciApp.style.left   = r.left + 'px';
    ciApp.style.width  = Math.max(640, vw - r.left) + 'px';
    ciApp.style.height = Math.max(360, vh - r.top)  + 'px';
    ciApp.style.zIndex = '1';
  }
  window.addEventListener('resize', sizeApp);
  window.addEventListener('scroll', sizeApp, { passive: true });
  // Recompute when the CP sidebar collapses/expands (changes the left edge).
  if (window.ResizeObserver) new ResizeObserver(sizeApp).observe(document.body);
  sizeApp();
  setTimeout(sizeApp, 50);
  window.addEventListener('load', sizeApp);

  // DOM
  const iframe    = document.getElementById('xr-iframe');
  const addr      = document.getElementById('addr');
  const btnGo     = document.getElementById('btn-go');
  const btnReload = document.getElementById('btn-reload');
  const btnInsp   = document.getElementById('btn-inspect');
  const statusEl  = document.getElementById('xr-status');
  const sbBody    = document.getElementById('sb-body');
  const tabComponentContent = document.getElementById('tab-component-content');
  const tabGlobalsContent = document.getElementById('tab-globals-content');
  const globalsLoading = document.getElementById('globals-loading');
  const globalsList = document.getElementById('globals-list');
  const emptyEl   = document.getElementById('empty');
  const progress  = document.getElementById('progress');
  // State
  let inspecting   = false;
  let iframeReady  = false;
  let currentUrl   = BASE;
  let hovered      = [];
  let selected     = null;   // { chain, idx }
  let lastChain    = [];     // last data passed to render()
  let lastIdx      = 0;

  // ── URL utils ──────────────────────────────────────────────────────────
  function withInspect(url) {
    try {
      const u = new URL(url, location.origin);
      u.searchParams.set(PARAM, '1');
      return u.toString();
    } catch { return url + (url.includes('?') ? '&' : '?') + PARAM + '=1'; }
  }
  function withoutInspect(url) {
    try {
      const u = new URL(url, location.origin);
      u.searchParams.delete(PARAM);
      return u.toString();
    } catch { return url; }
  }

  function isLocalUrl(url) {
    if (!url) return true;
    try {
      const baseHost = new URL(BASE).host;
      // Resolving against BASE handles every shape consistently: relative paths
      // ("/games"), protocol-relative ("//evil.com" → external), and absolute
      // URLs. The old hand-rolled parsing treated "//evil.com" as local.
      const u = new URL(url, BASE);
      return u.host === baseHost;
    } catch {
      return false;
    }
  }

  // ── Navigation ─────────────────────────────────────────────────────────
  function navigate(url) {
    if (!url || url.trim() === '') url = BASE;
    // Keep navigation on the project host when external nav is blocked.
    if (CONFIG.blockExternalNav && !isLocalUrl(url)) {
      url = BASE;
    }

    // Resolve URL to check 404 status
    let checkUrl = url;
    try {
      if (!url.includes('://')) {
        checkUrl = new URL(url, BASE).toString();
      }
    } catch (e) {}

    if (isLocalUrl(checkUrl) && checkUrl !== BASE && checkUrl !== BASE + '/') {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 2000);

      // HEAD, not GET: we only need the status code to detect a 404. Using GET
      // here downloaded the whole page a second time (the iframe loads it too).
      fetch(checkUrl, { method: 'HEAD', credentials: 'same-origin', signal: controller.signal })
        .then(response => {
          clearTimeout(timeoutId);
          if (response.status === 404) {
            navigate(BASE);
          } else {
            proceed(url);
          }
        })
        .catch(() => {
          clearTimeout(timeoutId);
          proceed(url);
        });
    } else {
      proceed(url);
    }
  }

  function proceed(url) {
    // New page → its component tokens are different; drop the old prop caches
    // so they don't grow without bound across a long inspection session.
    propCache = {};
    inflight = {};
    currentUrl = url;
    addr.value = withoutInspect(url);
    setStatus('loading');
    progress.classList.add('run');
    iframe.classList.add('dim');
    iframeReady = false;
    iframe.src = withInspect(url);
  }

  // ── Status ─────────────────────────────────────────────────────────────
  function setStatus(s, label) {
    statusEl.className = 'xr-' + s;
    const labels = { idle: 'Idle', loading: 'Loading…', ready: 'Ready' };
    statusEl.textContent = label ?? labels[s] ?? s;
  }

  // ── Inspect toggle ──────────────────────────────────────────────────────
  function setInspect(on) {
    inspecting = on;
    btnInsp.classList.toggle('on', on);
    btnInsp.querySelector('.btn-label').textContent = on ? 'Active' : 'Inspect';
    if (iframeReady) {
      iframe.contentWindow.postMessage({ type: on ? 'xr:enable' : 'xr:disable' }, FRAME_ORIGIN);
    }
  }
  btnInsp.addEventListener('click', () => setInspect(!inspecting));

  // Alt+I keyboard shortcut
  document.addEventListener('keydown', e => {
    if (e.altKey && e.key.toLowerCase() === 'i') { e.preventDefault(); setInspect(!inspecting); }
  });

  // ── Sidebar rendering ──────────────────────────────────────────────────
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function formatHtml(html) {
    let formatted = '';
    let indent = '';
    const tab = '  ';

    // Split by tags
    const tokens = html.split(/(<\/?[a-zA-Z0-9_\-]+(?:\s+[^>]*?)?>)/);

    for (let i = 0; i < tokens.length; i++) {
      const token = tokens[i];
      if (!token) continue;

      const isTag = token.startsWith('<');
      const isClosing = token.startsWith('</');
      const cleanTagName = token.replace(/[<\/>]/g, '').split(/\s+/)[0];
      const isBlock = isTag && /^(p|ul|ol|li|div|h[1-6]|pre|blockquote|table|tr|td|th|thead|tbody|tfoot|section|article)$/i.test(cleanTagName);

      if (isTag) {
        if (isBlock) {
          if (isClosing) {
            indent = indent.substring(0, indent.length - tab.length);
            formatted += '\n' + indent + token;
          } else {
            formatted += (formatted ? '\n' : '') + indent + token;
            const isSelfClosing = /\/>$/.test(token) || /^(br|hr|img|input|meta|link)$/i.test(cleanTagName);
            if (!isSelfClosing) {
              indent += tab;
            }
          }
        } else {
          // Inline tag
          formatted += token;
        }
      } else {
        // Text content
        const text = token.trim();
        if (text) {
          if (formatted.endsWith('\n') || formatted === '') {
            formatted += indent + token.trim();
          } else {
            formatted += token;
          }
        }
      }
    }
    return formatted.replace(/\n\s*\n/g, '\n').trim();
  }

  function renderHtmlType(v) {
    const textLen = v.length ?? 0;
    const htmlContent = v.html ?? '';
    const formattedHtmlString = formatHtml(htmlContent);
    const truncNote = v.truncated ? ' <span style="opacity:0.7;">(preview truncated)</span>' : '';
    const summary = `<span style="color:var(--muted);font-style:italic;">&lt;${textLen} chars of HTML&gt;${truncNote}</span>`;
    const id = 'xr-html-' + Math.random().toString(36).substr(2, 9);
    const val = `
      <div class="xr-html-container" style="display:inline-block;vertical-align:middle;width:100%;">
        ${summary}
        <button class="xr-html-toggle" onclick="const pre=document.getElementById('${id}'); const show=pre.style.display==='none'; pre.style.display=show?'block':'none'; this.textContent=show?'hide markup':'show markup'; return false;" style="margin-left:8px;font-family:var(--sans);font-size:9.5px;padding:1px 6px;border-radius:4px;background:var(--surface2);border:1.5px solid var(--border);color:var(--text-2);cursor:pointer;font-weight:600;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-2)';">show markup</button>
        <pre id="${id}" class="xr-html-raw" style="display:none;margin-top:6px;margin-bottom:0;padding:8px 10px;background:var(--bg);border:1px solid var(--border);border-radius:4px;font-family:var(--mono);font-size:10px;line-height:1.4;white-space:pre-wrap;word-break:break-all;color:var(--text-2);max-height:200px;overflow-y:auto;">${esc(formattedHtmlString)}</pre>
      </div>
    `;
    return [val, 'obj'];
  }

  function renderVal(v) {
    if (v === null || v === undefined) return ['null', 'null'];
    if (typeof v === 'boolean') return [String(v), 'bool'];
    if (typeof v === 'number')  return [String(v), 'num'];
    if (typeof v === 'string') {
      const s = v.length > 140 ? v.slice(0,140) + '…' : v;
      return ['"' + esc(s) + '"', 'str'];
    }
    if (typeof v === 'object') {
      if (v.__type === 'Html') {
        return renderHtmlType(v);
      }
      if (v.__type === 'Element') {
        const text = esc(`<${v.__element?.split('\\').pop()}> #${v.id} "${v.title || ''}"`);
        const val = (v.editUrl && CONFIG.showEditLinks)
          ? `<a href="${esc(v.editUrl)}" target="_blank" class="xr-prop-link" title="Edit in Admin">${text}<svg class="xr-prop-link-ic" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>`
          : text;
        return [val, 'obj'];
      }
      if (v.__type === 'Option') {
        const label = v.label && v.label !== v.value ? ` <span style="color:var(--muted);font-weight:400">(${esc(v.label)})</span>` : '';
        return [`"${esc(v.value ?? '')}"${label}`, 'str'];
      }
      if (v.__type === 'MultiSelect') {
        if (!v.selected || v.selected.length === 0) return ['(none selected)', 'null'];
        const tags = v.selected.map(o => `<span style="background:var(--accent-soft);color:var(--accent-h);border-radius:4px;padding:0 5px;font-size:10px;">${esc(o.value ?? '')}</span>`).join(' ');
        return [tags, ''];
      }
      if (v.__type === 'Color') {
        const swatch = `<span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:${esc(v.hex)};border:1px solid rgba(0,0,0,.2);vertical-align:middle;margin-right:4px;"></span>`;
        return [`${swatch}${esc(v.hex)}`, 'str'];
      }
      if (v.__type === 'Link') {
        const label = v.label ? ` — "${esc(v.label)}"` : '';
        const url = esc(v.url || '');
        return [`<a href="${url}" target="_blank" class="xr-prop-link">${url}</a>${label}`, 'str'];
      }
      if (v.__type === 'ElementCollection') return [esc(`[Collection: ${v.__count} item${v.__count === 1 ? '' : 's'}]`), 'obj'];
      if (v.__type === 'ElementQuery') { const qc = v.class?.split('\\').pop() || 'ElementQuery'; return [esc(`\u003c${qc}\u003e`), 'obj']; }
      if (v.__type === 'Object') return [esc(`{${v.class?.split('\\').pop()}}`), 'obj'];
      if (Array.isArray(v)) return [`Array(${v.length})`, 'obj'];
      return [esc(JSON.stringify(v).slice(0,80)), 'obj'];
    }
    return [esc(String(v)), ''];
  }

  // A plain array or object (map) — i.e. something worth expanding, as opposed
  // to a scalar or a special serialized Craft value (Element, ElementCollection…).
  function isPlainObject(v) {
    return v && typeof v === 'object' && !Array.isArray(v) && !v.__type;
  }
  function isExpandable(v) {
    return Array.isArray(v) || isPlainObject(v);
  }

  // Render a scalar / special value as a block (keeps the left accent bar).
  function renderLeaf(v) {
    const [disp, cls] = renderVal(v);
    return `<div class="pv ${cls}">${disp}</div>`;
  }
  // Inline variant used inside tree rows (no accent bar / block spacing).
  function renderLeafInline(v) {
    const [disp, cls] = renderVal(v);
    return `<span class="pv ${cls}">${disp}</span>`;
  }

  // Recursively render an array/object as a collapsible tree. Nested arrays &
  // objects get their own expander; scalars render inline. Top level (depth 0)
  // starts expanded, deeper levels collapsed so big structures stay tidy.
  function renderTree(v, depth) {
    if (depth > 12) return '<span class="pv obj">…</span>';

    const isArr = Array.isArray(v);
    const keys  = isArr ? v.map((_, i) => i) : Object.keys(v);

    if (!keys.length) {
      return `<span class="pv obj">${isArr ? '[ ] empty array' : '{ } empty object'}</span>`;
    }

    const label = isArr ? 'Array' : 'Object';
    const rows = keys.map(k => {
      const child = v[k];
      const cell = isExpandable(child) ? renderTree(child, depth + 1) : renderLeafInline(child);
      return `<div class="xr-tree-row">
        <span class="xr-tree-key">${esc(k)}${isArr ? '' : ':'}</span>
        ${cell}
      </div>`;
    }).join('');

    return `<details class="xr-tree-node"${depth === 0 ? ' open' : ''}>
      <summary class="xr-tree-sum">${label} <span class="xr-tree-count">${keys.length}</span></summary>
      <div class="xr-tree-body">${rows}</div>
    </details>`;
  }

  function propsTable(props) {
    const types = (props && props.__propTypes) || {};
    const entries = Object.entries(props || {}).filter(([k]) => k !== '__propTypes');
    if (!entries.length) return '<p class="no-props">No props passed.</p>';
    let h = '<div class="props-list">';
    for (const [k, v] of entries) {
      const typeLabel = types[k];
      const typeBadge = typeLabel
        ? `<span class="xr-prop-type">${esc(typeLabel)}</span>`
        : '';
      const valHtml = isExpandable(v)
        ? `<div class="pv-tree">${renderTree(v, 0)}</div>`
        : renderLeaf(v);
      h += `<div class="prop-item">
        <div class="pk">${esc(k)}${typeBadge}</div>
        ${valHtml}
      </div>`;
    }
    return h + '</div>';
  }

  function basename(p) { return p ? p.split('/').pop() : p; }

  // Real path the loader emitted (relative to templates root), shown under
  // templates/. Falls back to a name-based guess only for older payloads that
  // didn't carry the real path.
  function filePath(component, file) {
    return 'templates/' + (file || (component + '.twig'));
  }

  // Badge: how many times this template was rendered on the current page.
  function renderCountBadge(count) {
    const n = (typeof count === 'number' && count > 0) ? count : null;
    if (n === null) return '';
    const noun = n === 1 ? 'time' : 'times';
    return `<span class="xr-count-badge" title="This template was rendered ${n} ${noun} on the current page">${n}× on page</span>`;
  }

  function roleBadge(i, len) {
    if (i === 0)        return '<span class="xr-badge xr-badge-inner">innermost</span>';
    if (i === len - 1)  return '<span class="xr-badge xr-badge-root">outermost</span>';
    return '<span class="xr-badge xr-badge-parent">parent</span>';
  }

  const ICON_FOLDER = '<svg class="xr-ic" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7.5a2 2 0 0 1 2-2h3.3a2 2 0 0 1 1.4.6l1 1H19a2 2 0 0 1 2 2v6.4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>';
  const ICON_FILE   = '<svg class="xr-ic" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M13 3v5h5"/><path d="M13 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/></svg>';

  // ── IDE deep-link registry ─────────────────────────────────────────────────
  // Each entry: { label, icon (locally-bundled logo), url(path) }
  // All URL schemes are real, tested protocol handlers registered by each app.
  //
  // VS Code / Cursor / Windsurf: vscode://file/{path}
  // PHPStorm / WebStorm / IntelliJ: jetbrains://...(gateway) OR legacy phpstorm://open?...
  //   — We use the per-app legacy scheme (registered since v2016.x), which is
  //     the most universally supported without needing Toolbox.
  // Zed: zed://file/{path}
  // Sublime Text: subl://open?url=file://{path}
  // Nova: nova://open?path={path}
  //
  // Logos are served from the locally-bundled CP asset (no external requests).
  const ICONS = CONFIG.editorIconsBaseUrl;
  const EDITORS = {
    vscode: {
      label: 'VS Code',
      icon:  ICONS + '/vscode.svg',
      // vscode://file/{absolutePath}:{line} — works on macOS, Win, Linux
      url: (p) => `vscode://file/${encodeURI(p)}`,
    },
    cursor: {
      label: 'Cursor',
      // Cursor uses the same vscode:// handler with a "cursor" scheme alias
      // registered when you install Cursor (confirmed in Cursor docs).
      icon:  ICONS + '/cursor.png',
      url: (p) => `cursor://file/${encodeURI(p)}`,
    },
    windsurf: {
      label: 'Windsurf',
      // Windsurf (Codeium) registers windsurf:// on install (same VS Code fork pattern)
      icon:  ICONS + '/windsurf.svg',
      url: (p) => `windsurf://file/${encodeURI(p)}`,
    },
    phpstorm: {
      label: 'PHPStorm',
      icon:  ICONS + '/phpstorm.svg',
      // phpstorm://open?file={path}&line=1 — registered by the JetBrains IDE on install
      url: (p) => `phpstorm://open?file=${encodeURIComponent(p)}&line=1`,
    },
    webstorm: {
      label: 'WebStorm',
      icon:  ICONS + '/webstorm.svg',
      url: (p) => `webstorm://open?file=${encodeURIComponent(p)}&line=1`,
    },
    idea: {
      label: 'IntelliJ IDEA',
      icon:  ICONS + '/intellij.svg',
      url: (p) => `idea://open?file=${encodeURIComponent(p)}&line=1`,
    },
    zed: {
      label: 'Zed',
      // zed://file/{path} — documented in Zed's URL scheme spec
      icon:  ICONS + '/zed.png',
      url: (p) => `zed://file/${encodeURI(p)}`,
    },
    sublime: {
      label: 'Sublime Text',
      icon:  ICONS + '/sublime.png',
      // subl://open?url=file://{path}&line=1 — requires "subl" command line tool in PATH
      url: (p) => `subl://open?url=file://${encodeURI(p)}&line=1`,
    },
    nova: {
      label: 'Nova',
      // nova://open?path={path} — macOS-only, documented in Panic's Nova URL scheme
      icon:  ICONS + '/nova.svg',
      url: (p) => `nova://open?path=${encodeURIComponent(p)}`,
    },
  };

  // Build the deep-link URL for a given editor key + component token.
  // Uses CONFIG.templatesPath (absolute) so the editor can locate the file.
  // e.g. /Users/thereza/Desktop/craftcms-project/templates/_components/_card.twig
  function editorUrl(editorKey, component, file) {
    const editor = EDITORS[editorKey];
    if (!editor) return null;
    const absPath = CONFIG.templatesPath + '/' + (file || (component + '.twig'));
    return editor.url(absPath);
  }

  // ── Active picker state (one at a time) ────────────────────────────────────
  let activePicker = null;
  function closeActivePicker() {
    if (activePicker) { activePicker.classList.remove('open'); activePicker = null; }
  }
  document.addEventListener('click', (e) => {
    if (activePicker && !activePicker.closest('.xr-editor-btn-wrap')?.contains(e.target)) {
      closeActivePicker();
    }
  }, true);

  // Build the editor button HTML (and its picker for Variable mode).
  function editorBtnHtml(component, file) {
    const ICON_EDITOR = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`;
    const LABEL = `<span>Code</span>`;
    const fileAttr = file ? ` data-file="${esc(file)}"` : '';

    if (CONFIG.editorMode === 'default') {
      // Fire immediately on click — no picker needed.
      const editor = EDITORS[CONFIG.defaultEditor] || EDITORS['vscode'];
      return `<span class="xr-editor-btn-wrap" style="position:relative;display:inline-flex;">
        <button class="xr-editor-btn" title="Open in ${esc(editor.label)}" data-editor-fire data-component="${esc(component)}"${fileAttr}>${ICON_EDITOR}${LABEL}</button>
      </span>`;
    }

    // Variable mode: show a picker with all editors.
    const opts = Object.entries(EDITORS).map(([key, ed]) => {
      const isDefault = key === CONFIG.defaultEditor;
      return `<button class="xr-editor-opt${isDefault ? ' active' : ''}" data-editor-pick data-key="${esc(key)}" data-component="${esc(component)}"${fileAttr}>
        <img src="${esc(ed.icon)}" alt="${esc(ed.label)}" loading="lazy">
        <span class="xr-editor-opt-name">${esc(ed.label)}</span>
        ${isDefault ? '<span class="xr-editor-opt-check">✓</span>' : ''}
      </button>`;
    }).join('');

    return `<span class="xr-editor-btn-wrap" style="position:relative;display:inline-flex;">
      <button class="xr-editor-btn" title="Open in editor…" data-editor-toggle data-component="${esc(component)}">${ICON_EDITOR}${LABEL}</button>
      <div class="xr-editor-picker">
        <div class="xr-editor-picker-title">Open in editor</div>
        ${opts}
      </div>
    </span>`;
  }

  // Attach editor button events after innerHTML is set.
  function bindEditorButtons(root) {
    // Default mode — direct fire.
    root.querySelectorAll('[data-editor-fire]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const url = editorUrl(CONFIG.defaultEditor, btn.dataset.component, btn.dataset.file);
        if (url) window.location.href = url;
      });
    });

    // Variable mode — toggle picker open/closed.
    root.querySelectorAll('[data-editor-toggle]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const picker = btn.nextElementSibling;
        if (!picker) return;
        const isOpen = picker.classList.contains('open');
        closeActivePicker();
        if (!isOpen) { picker.classList.add('open'); activePicker = picker; }
      });
    });

    // Variable mode — pick and fire.
    root.querySelectorAll('[data-editor-pick]').forEach(opt => {
      opt.addEventListener('click', (e) => {
        e.stopPropagation();
        const url = editorUrl(opt.dataset.key, opt.dataset.component, opt.dataset.file);
        closeActivePicker();
        if (url) window.location.href = url;
      });
    });
  }

  // Render the file path as a nested folder/file tree.
  function locationTree(component, file) {
    const segs = filePath(component, file).split('/');
    return '<div class="xr-loc">' + segs.map((seg, i) => {
      const isFile = i === segs.length - 1;
      return `<div class="xr-loc-row ${isFile ? 'xr-loc-file' : 'xr-loc-folder'}" style="padding-left:${i * 16}px">
        ${isFile ? ICON_FILE : ICON_FOLDER}
        <span class="xr-loc-name">${esc(seg)}</span>
      </div>`;
    }).join('') + '</div>';
  }

  // ── Lazy props ──────────────────────────────────────────────────────────
  // Props are no longer inlined in the page; we fetch them by token on demand
  // and cache them client-side so re-hovers/selects don't refetch.
  let propCache = {};   // token → props object
  let inflight  = {};   // token → Promise (dedupe concurrent fetches)

  function fetchProps(token) {
    if (!token) return Promise.resolve({});
    if (propCache[token]) return Promise.resolve(propCache[token]);
    if (inflight[token]) return inflight[token];

    const url = CONFIG.componentPropsUrl +
      (CONFIG.componentPropsUrl.includes('?') ? '&' : '?') + 'cid=' + encodeURIComponent(token);

    inflight[token] = fetch(url, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
      .then(r => r.json())
      .then(d => {
        const props = (d && d.props) ? d.props : (d && d.expired ? { __expired: true } : {});
        propCache[token] = props;
        delete inflight[token];
        return props;
      })
      .catch(() => {
        propCache[token] = { __error: true };
        delete inflight[token];
        return { __error: true };
      });

    return inflight[token];
  }

  // Resolve the cached props for a chain entry (null until loaded).
  function resolveProps(entry) {
    if (!entry) return {};
    if (!entry.id) return entry.props || {};   // back-compat / no token
    return propCache[entry.id] || null;
  }

  // Render the selected component's identity, file location, hierarchy & props.
  function render(chain, selIdx) {
    lastChain = chain || [];
    lastIdx   = selIdx || 0;

    if (!lastChain.length) {
      tabComponentContent.innerHTML = '';
      tabComponentContent.appendChild(emptyEl);
      emptyEl.style.display = 'flex';
      return;
    }
    emptyEl.style.display = 'none';

    const sel       = lastChain[lastIdx] || lastChain[0];
    const path      = filePath(sel.component, sel.file);
    const props     = resolveProps(sel);          // null while still loading
    const ready     = props !== null;
    const propCount = ready
      ? Object.keys(props).filter(k => k !== '__propTypes').length
      : '…';
    const depth     = lastChain.length;

    // Hierarchy section — only when the component is actually nested.
    let hierarchy = '';
    if (depth > 1) {
      let tree = '';
      for (let d = 0; d < depth; d++) {
        const i = depth - 1 - d;               // original index (innermost-first)
        const item = lastChain[i];
        tree += `<button class="xr-node${i===lastIdx?' sel':''}" data-i="${i}" style="padding-left:${10 + d*16}px">
          ${d > 0 ? '<span class="xr-node-twig">└─</span>' : ''}
          <span class="xr-node-name">${esc(basename(item.component))}</span>
          ${item.count > 1 ? `<span class="xr-node-count" title="Rendered ${item.count} times on this page">×${item.count}</span>` : ''}
          ${i === 0 ? '<span class="xr-node-tag">hovered</span>' : ''}
        </button>`;
      }
      hierarchy = `<section class="xr-sec">
        <div class="xr-sec-hd">Hierarchy <span class="xr-sec-meta">${depth}</span></div>
        <div class="xr-tree">${tree}</div>
      </section>`;
    }

    tabComponentContent.innerHTML = `
      <section class="xr-sec">
        <div class="xr-sec-hd">Project URL</div>
        <div class="xr-name-row">
          <a href="${esc(BASE)}" target="_blank" style="font-family: var(--mono); font-size: 11px; color: var(--accent); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; font-weight: 500;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">
            ${esc(BASE)}
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.75;">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>
      </section>

      <section class="xr-sec">
        <div class="xr-sec-hd">Component</div>
        <div class="xr-name-row">
          <span class="xr-name">${esc(basename(sel.component))}</span>
          ${renderCountBadge(sel.count)}
        </div>
      </section>

      <section class="xr-sec">
        <div class="xr-sec-hd">Location
          <div style="display:flex;align-items:center;gap:5px;margin-left:auto;">
            ${editorBtnHtml(sel.component, sel.file)}
            <button class="xr-copy" data-copy="${esc(path)}" title="Copy path">
              <span class="xr-copy-ic" aria-hidden="true">⧉</span><span>Copy</span>
            </button>
          </div>
        </div>
        ${locationTree(sel.component, sel.file)}
      </section>

      ${hierarchy}

      <section class="xr-sec">
        <div class="xr-sec-hd">Props <span class="xr-sec-meta">${propCount}</span></div>
        ${ready
          ? (props.__expired
              ? '<p class="no-props">Props expired — reload the page to re-capture.</p>'
              : (props.__error
                  ? '<p class="no-props">Failed to load props.</p>'
                  : propsTable(props)))
          : '<p class="no-props">Loading props…</p>'}
      </section>`;

    // Lazily fetch props for this component, then re-render in place.
    if (sel.id && !ready) {
      fetchProps(sel.id).then(() => {
        // Only re-render if this same entry is still the one on screen.
        if ((lastChain[lastIdx] || {}).id === sel.id) render(lastChain, lastIdx);
      });
    }

    // Hierarchy nodes select that level (and lock the selection).
    tabComponentContent.querySelectorAll('.xr-node').forEach(n =>
      n.addEventListener('click', () => { selected = { chain: lastChain, idx: +n.dataset.i }; render(lastChain, +n.dataset.i); })
    );

    // Editor deep-link buttons.
    bindEditorButtons(tabComponentContent);

    // Copy the file path.
    const copyBtn = tabComponentContent.querySelector('.xr-copy');
    if (copyBtn) copyBtn.addEventListener('click', () => {
      navigator.clipboard?.writeText(copyBtn.dataset.copy).then(() => {
        const label = copyBtn.querySelector('span:last-child');
        label.textContent = 'Copied';
        copyBtn.classList.add('done');
        setTimeout(() => { label.textContent = 'Copy'; copyBtn.classList.remove('done'); }, 1200);
      }).catch(() => {});
    });

  }

  // ── postMessage from iframe ────────────────────────────────────────────
  window.addEventListener('message', e => {
    // Only trust messages from the inspected site itself. Without this, any
    // page the iframe was steered to (or any other frame) could post a crafted
    // xr:select/xr:hover payload into the CP.
    if (FRAME_ORIGIN !== '*' && e.origin !== FRAME_ORIGIN) return;
    if (e.source !== iframe.contentWindow) return;
    if (!e.data?.type) return;
    switch (e.data.type) {
      case 'xr:ready':
        iframeReady = true;
        iframe.classList.remove('dim');
        progress.classList.remove('run');
        setStatus('ready');
        if (inspecting) iframe.contentWindow.postMessage({ type: 'xr:enable' }, FRAME_ORIGIN);
        // sync address bar
        try { addr.value = withoutInspect(iframe.contentWindow.location.href); } catch {}
        break;
      case 'xr:hover':
        hovered = e.data.chain || [];
        if (!selected) render(hovered, 0);
        break;
      case 'xr:select':
        selected = { chain: e.data.chain || [], idx: 0 };
        render(selected.chain, 0);
        break;
    }
  });

  // ── iframe load ────────────────────────────────────────────────────────
  iframe.addEventListener('load', () => {
    // Same-origin, so we can read where the frame actually landed. This covers
    // link clicks, form posts and JS redirects that happen *inside* the frame.
    let href = null;
    let crossOrigin = false;
    try {
      href = iframe.contentWindow.location.href;
    } catch (e) {
      crossOrigin = true;
    }

    if (crossOrigin) {
      // The frame landed on a cross-origin page. When external nav is blocked,
      // bounce back to the project URL; otherwise just leave it be.
      if (CONFIG.blockExternalNav) navigate(BASE);
      return;
    }

    if (href && !PARAM_RE.test(href)) {
      // An internal navigation dropped the inspect flag → re-add it so the
      // client script gets re-injected and inspection keeps working.
      currentUrl = withoutInspect(href);
      iframe.src = withInspect(href);
      return; // a second load fires with the flag present
    }

    if (href) {
      currentUrl  = withoutInspect(href);
      addr.value  = currentUrl;          // keep the address bar in sync
    }
    try { iframe.contentWindow.postMessage({ type: 'xr:ping' }, FRAME_ORIGIN); } catch {}
  });

  // ── Controls ───────────────────────────────────────────────────────────
  btnGo.addEventListener('click', () => { selected = null; navigate(addr.value); });
  addr.addEventListener('keydown', e => { if (e.key === 'Enter') { selected = null; navigate(addr.value); } });
  btnReload.addEventListener('click', () => {
    selected = null;
    try {
      iframe.contentWindow.location.reload(true);
    } catch (err) {
      navigate(currentUrl);
    }
  });

  // ── Sidebar Tabs switching ─────────────────────────────────────────────
  const tabs = document.querySelectorAll('.sb-tab');
  tabs.forEach(t => {
    t.addEventListener('click', () => {
      tabs.forEach(btn => btn.classList.remove('active'));
      t.classList.add('active');
      const activeTab = t.dataset.tab;
      if (activeTab === 'component') {
        tabComponentContent.style.display = 'block';
        tabGlobalsContent.style.display = 'none';
      } else {
        tabComponentContent.style.display = 'none';
        tabGlobalsContent.style.display = 'block';
        loadGlobalSets();
      }
    });
  });

  // ── Global Sets loading & rendering ────────────────────────────────────
  let globalSetsCache = null;

  function loadGlobalSets() {
    if (globalSetsCache) {
      renderGlobalSets(globalSetsCache);
      return;
    }
    globalsLoading.style.display = 'block';
    globalsList.innerHTML = '';

    const apiUrl = CONFIG.componentPropsUrl.replace('component-props', 'global-sets');

    fetch(apiUrl, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
      .then(r => r.json())
      .then(d => {
        globalSetsCache = (d && d.globalSets) ? d.globalSets : [];
        renderGlobalSets(globalSetsCache);
      })
      .catch(err => {
        globalsLoading.textContent = 'Failed to load Global Sets.';
      });
  }

  function globalsTable(fields) {
    if (!fields || !fields.length) return '<p class="no-props">No fields defined.</p>';
    let h = '<div class="props-list">';
    for (const f of fields) {
      const typeBadge = f.type
        ? `<span class="xr-prop-type">${esc(f.type)}</span>`
        : '';
      const valHtml = isExpandable(f.value)
        ? `<div class="pv-tree">${renderTree(f.value, 0)}</div>`
        : renderLeaf(f.value);
      h += `<div class="prop-item">
        <div class="pk">${esc(f.name || f.handle)}${typeBadge} <span style="font-weight:normal;color:var(--muted);font-size:10px;font-family:var(--mono);">.${esc(f.handle)}</span></div>
        ${valHtml}
      </div>`;
    }
    return h + '</div>';
  }

  function renderGlobalSets(sets) {
    globalsLoading.style.display = 'none';
    if (!sets || sets.length === 0) {
      globalsList.innerHTML = '<p class="no-props" style="padding: 0 14px;">No Global Sets found on this site.</p>';
      return;
    }

    globalsList.innerHTML = sets.map(set => {
      const fieldsTableHtml = globalsTable(set.fields);
      const editBtn = (set.editUrl && CONFIG.showEditLinks)
        ? `<a href="${esc(set.editUrl)}" target="_blank" class="xr-copy" title="Edit Global Set" style="margin-left: auto; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; height: 24px; padding: 0 8px; border-radius: 4px; border: 1px solid var(--border); background: transparent; color: var(--muted); font-size: 10px; font-weight: 600;">
             <span class="xr-copy-ic" aria-hidden="true" style="font-size: 10px; margin-right: 2px;">✎</span><span>Edit</span>
           </a>`
        : '';

      return `<section class="xr-sec" style="border-bottom: 1px solid var(--border); padding-bottom: 24px; padding-left: 14px; padding-right: 14px;">
        <div class="xr-sec-hd" style="background: transparent; border: none; padding: 0; margin-bottom: 8px;">
          <span class="xr-name" style="font-size: 14px;">${esc(set.name)}</span>
          ${editBtn}
        </div>
        <div class="xr-name-row" style="margin-bottom: 12px;">
          <span style="font-family: var(--mono); font-size: 10.5px; color: var(--muted);">handle: <strong>globalSets.${esc(set.handle)}</strong></span>
        </div>
        ${fieldsTableHtml}
      </section>`;
    }).join('');
  }

  // ── Boot ───────────────────────────────────────────────────────────────
  navigate(BASE);
})();
</script>
{% endblock %}
